    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0"
  },
  "private": true
}
