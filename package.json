    "ios": "expo start --ios",
    "web": "expo start --web",
    "demo": "node scripts/demo.js",
    "test": "node scripts/smoke-test.js",
    "check:syntax": "node --check App.js && node --check server/index.js && node --check server/db.js && node --check server/pages.js && node --check scripts/smoke-test.js && node --check scripts/h5-interaction-layout-check.js && node --check scripts/start-wechat-demo.js && node --check scripts/prepare-github-pages.js",
    "server": "node server/index.js",
    "dev:api": "node server/index.js",
    "preview:h5": "node scripts/serve-h5-preview.js",
    "wechat:demo": "node scripts/start-wechat-demo.js",
    "build:web:demo": "expo export --platform web --output-dir dist/wechat-demo",
    "build:pages": "expo export --platform web --output-dir release/github-pages-deploy && node scripts/prepare-github-pages.js",
    "export:android": "expo export --platform android --output-dir dist/android",
    "check:h5": "node scripts/h5-interaction-layout-check.js",
    "build:android:preview": "eas build -p android --profile preview",
    "build:android:production": "eas build -p android --profile production",
    "submit:android": "eas submit -p android --profile production"
